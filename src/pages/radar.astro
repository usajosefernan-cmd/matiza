---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getDatabase } from '../lib/db.js';

// Cargar envíos recientes del radar para mostrarlos de forma anónima
const db = getDatabase();

const submissions = db.prepare(`
  SELECT * FROM user_submissions 
  ORDER BY created_at DESC 
  LIMIT 15
`).all() as any[];

db.close();

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;

function getStatusBadgeClass(status: string) {
  const s = status.toLowerCase();
  if (s === 'recibido') return 'amber';
  if (s === 'en_cola') return 'purple';
  if (s === 'investigando') return 'blue';
  if (s === 'publicado') return 'green';
  if (s === 'descartado_por_baja_relevancia') return 'rose';
  return 'muted';
}

function getStatusLabel(status: string) {
  const s = status.toLowerCase();
  if (s === 'recibido') return 'Recibido';
  if (s === 'en_cola') return 'En cola';
  if (s === 'investigando') return 'Investigando';
  if (s === 'publicado') return 'Publicado';
  if (s === 'descartado_por_baja_relevancia') return 'Descartado';
  return status;
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
}
---

<Layout title="Buzón del Radar — Hermes Engine" description="Audita links virales sospechosos en caliente con bases de datos oficiales.">
  <div id="radar-app" class="container" data-base={cleanBase} style="max-width: 600px; padding: 2.5rem 1rem;">
    
    <!-- Volver -->
    <a href={cleanBase || "/"} style="text-decoration: none; color: var(--neon-blue); font-size: 0.8rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 1.5rem;">
      &larr; Volver al Portal
    </a>

    <!--  CABECERA CON RADAR GRÁFICO CHULO -->
    <section style="text-align: center; margin-bottom: 2rem;">
      <div class="radar-container">
        <div class="radar-sweep"></div>
        <div class="radar-grid"></div>
        <div class="radar-center"></div>
        <div class="radar-blip" id="radar-active-blip"></div>
      </div>

      <span class="pulse-dot-wrap" style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--neon-rose); letter-spacing: 0.15em; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
        <span class="pulse-dot" style="width: 8px; height: 8px; border-radius: 50%; display: inline-block;"></span>
        Radar de Intercepción Colaborativa
      </span>
      <h1 style="font-size: 2.1rem; font-weight: 900; letter-spacing: -0.04em; margin: 0 0 0.3rem 0; line-height: 1.1; font-family: var(--font-title); color: #fff;">
        Buzón del <span style="color: var(--neon-blue); text-shadow: 0 0 10px rgba(0, 240, 255, 0.3);">Radar</span>
      </h1>
      <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.45; max-width: 440px; margin: 0 auto;">
        Inserta un enlace sospechoso. Nuestro radar auditará su viralidad real y el impacto social del tema contrastándolo con fuentes oficiales en tiempo real.
      </p>
    </section>

    <!-- Caja del Formulario Cyberpunk con barra de escaneo -->
    <section class="cyber-card" style="padding: 1.85rem; background: linear-gradient(180deg, rgba(7, 9, 19, 0.95) 0%, rgba(18, 22, 41, 0.85) 100%); border-color: var(--neon-blue); box-shadow: 0 10px 30px rgba(0, 240, 255, 0.03); position: relative; overflow: hidden; margin-bottom: 3rem;">
      
      <!-- Barra de Escaneo que se desliza cuando se procesa -->
      <div id="scanning-laser" class="scanning-bar"></div>

      <form id="public-report-form" style="display: flex; flex-direction: column; gap: 1.25rem;">
        
        <div style="display: flex; flex-direction: column; gap: 0.35rem;">
          <label style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.08em; text-align: left;">Enlace de la publicación sospechosa:</label>
          <input type="url" id="report-url" name="url" placeholder="https://tiktok.com/@user/video/... o https://youtube.com/watch?v=..." required 
            style="width: 100%; padding: 0.75rem; background: rgba(0,0,0,0.6); border: 1px solid var(--border-color); border-radius: 8px; color: var(--text-main); font-size: 0.85rem; outline: none; transition: border-color 0.2s; box-sizing: border-box;" />
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.35rem;">
          <label style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.08em; text-align: left;">¿Qué se afirma en el bulo? (Opcional):</label>
          <textarea id="report-text" name="text" placeholder="Ej: Afirman que los autónomos tendrán una cuota del 50%..." rows="2"
            style="width: 100%; padding: 0.75rem; background: rgba(0,0,0,0.6); border: 1px solid var(--border-color); border-radius: 8px; color: var(--text-main); font-size: 0.85rem; outline: none; transition: border-color 0.2s; resize: none; box-sizing: border-box;"></textarea>
        </div>

        <button type="submit" id="submit-btn" class="cyber-btn accent" style="width: 100%; padding: 0.85rem; border-radius: 8px; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.08em; cursor: pointer; transition: all 0.2s ease;">
          Auditar Link en Radar
        </button>
      </form>

      <!-- 🖥️ CONSOLA DE LOGS EN VIVO -->
      <div id="console-wrapper" style="display: none; margin-top: 1.5rem; background: rgba(5, 7, 15, 0.95); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.15rem; font-family: monospace; font-size: 0.75rem; text-align: left; box-shadow: inset 0 0 10px rgba(0, 240, 255, 0.1); max-height: 250px; overflow-y: auto; scroll-behavior: smooth;">
        <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(0, 240, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
          <span style="color: var(--neon-blue); font-weight: 800; font-size: 0.7rem; letter-spacing: 0.05em; text-transform: uppercase; display: flex; align-items: center; gap: 0.35rem;">
            <span class="pulse-dot"></span> CONSOLA DE AUDITORÍA HERMES
          </span>
          <span id="console-status" style="color: var(--neon-amber); font-weight: bold; font-size: 0.65rem; text-transform: uppercase;">PROCESANDO...</span>
        </div>
        <div id="console-logs" style="display: flex; flex-direction: column; gap: 0.4rem; line-height: 1.4; color: var(--text-muted);">
          <!-- Logs dinámicos -->
        </div>
      </div>
    </section>

    <!-- Envíos recientes en el radar -->
    <section>
      <h2 style="font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 1.25rem; letter-spacing: -0.01em; display: flex; align-items: center; justify-content: space-between;">
        <span>Actividad del Radar Ciudadano</span>
        <span style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">Muestra de envíos recientes</span>
      </h2>

      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {submissions.map((sub: any) => (
          <div class="cyber-card" style="padding: 1rem; background: rgba(18, 22, 41, 0.3); display: flex; flex-direction: column; gap: 0.5rem;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <span class={`verdict-badge ${getStatusBadgeClass(sub.status)}`} style="font-size: 0.65rem; padding: 0.2rem 0.5rem; border-radius: 6px;">
                {getStatusLabel(sub.status)}
              </span>
              <span style="font-size: 0.65rem; color: var(--text-muted);">
                {formatDate(sub.created_at)}
              </span>
            </div>
            
            <p style="font-size: 0.85rem; color: var(--text-main); margin: 0; line-height: 1.35; font-style: italic;">
              "{sub.submitted_text || sub.submitted_url}"
            </p>

            {sub.reason && (
              <span style="font-size: 0.7rem; color: var(--text-muted); display: block; background: rgba(255,255,255,0.02); padding: 0.4rem; border-radius: 4px; border-left: 2px solid var(--border-color);">
                 Diagnóstico: {sub.reason}
              </span>
            )}
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const appEl = document.getElementById('radar-app');
    if (!appEl) return;

    const cleanBase = appEl.getAttribute('data-base') || '';

    const form = document.getElementById('public-report-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const consoleWrapper = document.getElementById('console-wrapper') as HTMLDivElement;
    const consoleLogs = document.getElementById('console-logs') as HTMLDivElement;
    const consoleStatus = document.getElementById('console-status') as HTMLSpanElement;
    const laser = document.getElementById('scanning-laser') as HTMLDivElement;
    const blip = document.getElementById('radar-active-blip') as HTMLDivElement;

    // Leer parámetros de URL para precargar campos
    const urlParams = new URLSearchParams(window.location.search);
    const paramUrl = urlParams.get('url');
    const paramText = urlParams.get('text');
    
    const urlInput = document.getElementById('report-url') as HTMLInputElement;
    const textInput = document.getElementById('report-text') as HTMLTextAreaElement;

    if (paramUrl) {
      if (urlInput) urlInput.value = paramUrl;
    }
    if (paramText) {
      const isUrl = paramText.trim().startsWith('http://') || paramText.trim().startsWith('https://');
      if (isUrl) {
        if (urlInput) urlInput.value = paramText.trim();
        if (textInput) {
          textInput.placeholder = 'Añade un comentario o aclaración sobre este enlace...';
          textInput.focus();
        }
      } else {
        if (textInput) textInput.value = paramText;
      }
    }

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const url = urlInput.value;
        const text = textInput.value;

        // Activar efectos visuales de escaneo
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.5';
        submitBtn.innerText = 'ESCANEANDO RED...';
        
        laser.style.display = 'block';
        if (blip) {
          blip.style.display = 'block';
          blip.style.animation = 'blipPulse 1s infinite';
        }
        
        consoleLogs.innerHTML = '';
        consoleWrapper.style.display = 'block';
        consoleStatus.innerText = 'ANALIZANDO';
        consoleStatus.style.color = 'var(--neon-amber)';

        const appendLog = (msg: string, type = 'info') => {
          const row = document.createElement('div');
          row.style.wordBreak = 'break-all';
          
          if (type === 'success') {
            row.style.color = '#00ffc4'; // neon green
          } else if (type === 'error') {
            row.style.color = '#ff3366'; // neon rose
          } else if (type === 'warn') {
            row.style.color = '#ffb020'; // neon amber
          } else {
            row.style.color = '#00f0ff'; // neon blue
          }
          
          row.innerText = `> ${msg}`;
          consoleLogs.appendChild(row);
          
          // Auto scroll
          consoleWrapper.scrollTop = consoleWrapper.scrollHeight;
        };

        try {
          appendLog('Iniciando auditoría de enlace local en caliente...', 'info');

          const response = await fetch(`${cleanBase}/api/report`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ url, text })
          });

          if (!response.ok) {
            const errData = await response.json().catch(() => ({}));
            throw new Error(errData.error || `Error HTTP ${response.status}`);
          }

          const reader = response.body.getReader();
          const decoder = new TextDecoder('utf-8');
          let buffer = '';
          let jobId = '';

          while (true) {
            const { value, done } = await reader.read();
            if (done) break;

            buffer += decoder.decode(value, { stream: true });
            const lines = buffer.split('\n');
            buffer = lines.pop() || ''; // Mantener el fragmento incompleto

            for (const line of lines) {
              if (line.trim()) {
                try {
                  const logObj = JSON.parse(line);
                  appendLog(logObj.message, logObj.status);
                  if (logObj.status === 'queued' && logObj.jobId) {
                    jobId = logObj.jobId;
                  }
                } catch (e) {
                  appendLog(line, 'info');
                }
              }
            }
          }

          if (jobId) {
            appendLog('Iniciando seguimiento de progreso en la cola...', 'info');
            
            // Iniciar polling
            const pollInterval = setInterval(async () => {
              try {
                const pollResp = await fetch(`${cleanBase}/api/job-status?id=${jobId}`);
                if (!pollResp.ok) return;

                const jobData = await pollResp.json();
                if (jobData.success) {
                  const phase = jobData.progress_phase || 'En cola';
                  const percent = jobData.progress_percent || 0;
                  
                  appendLog(`[Hermes] ${phase} (${percent}%)`, 'info');

                  if (jobData.status === 'completed') {
                    clearInterval(pollInterval);
                    appendLog('🎉 [AUDITORÍA FINALIZADA] El análisis ha concluido con éxito.', 'success');
                    appendLog(`🔗 Ver desmentido en vivo: http://localhost:4321/noticia/${jobData.slug}`, 'success');
                    
                    consoleStatus.innerText = 'COMPLETADO';
                    consoleStatus.style.color = '#00ffc4';

                    // Limpiar UI al terminar
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    submitBtn.innerText = 'Auditar Link en Radar';
                    laser.style.display = 'none';
                    if (blip) blip.style.display = 'none';
                    form.reset();

                    setTimeout(() => {
                      window.location.reload();
                    }, 8000);
                  } else if (jobData.status === 'failed') {
                    clearInterval(pollInterval);
                    appendLog(`❌ [Hermes] El procesamiento ha fallado: ${jobData.error_message || 'Error desconocido'}`, 'error');
                    consoleStatus.innerText = 'FALLIDO';
                    consoleStatus.style.color = '#ff3366';

                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    submitBtn.innerText = 'Auditar Link en Radar';
                    laser.style.display = 'none';
                    if (blip) blip.style.display = 'none';
                  }
                }
              } catch (pollErr: any) {
                console.error('Error en polling:', pollErr.message);
              }
            }, 2500);
          } else {
            throw new Error('No se pudo establecer conexión de cola con el motor.');
          }

        } catch (err: any) {
          appendLog(`Error: ${err.message}`, 'error');
          consoleStatus.innerText = 'ERROR';
          consoleStatus.style.color = '#ff3366';
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.innerText = 'Auditar Link en Radar';
          laser.style.display = 'none';
          if (blip) blip.style.display = 'none';
        }
      });
    }
  });
</script>

<style is:global>
  /*  ESTILOS DEL RADAR GRÁFICO */
  .radar-container {
    position: relative;
    width: 130px;
    height: 130px;
    margin: 0 auto 1.25rem auto;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 240, 255, 0.03) 0%, rgba(7, 9, 19, 0.95) 75%);
    border: 1px solid rgba(0, 240, 255, 0.2);
    overflow: hidden;
    box-shadow: 0 0 25px rgba(0, 240, 255, 0.05);
  }

  .radar-sweep {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(from 0deg, rgba(0, 240, 255, 0.15) 0deg, rgba(0, 240, 255, 0) 120deg);
    transform-origin: top left;
    transform: translate(-50%, -50%) rotate(0deg);
    animation: sweep 4s linear infinite;
    border-radius: 50%;
  }

  .radar-grid {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 50%;
    background: 
      radial-gradient(circle, transparent 25%, rgba(0, 240, 255, 0.08) 26%, transparent 27%, transparent 55%, rgba(0, 240, 255, 0.08) 56%, transparent 57%, transparent 80%, rgba(0, 240, 255, 0.08) 81%, transparent 82%),
      linear-gradient(to right, rgba(0, 240, 255, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 240, 255, 0.03) 1px, transparent 1px);
    background-size: 100% 100%, 15px 15px, 15px 15px;
    background-position: center;
  }

  .radar-center {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 6px;
    height: 6px;
    background-color: var(--neon-blue);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 8px var(--neon-blue);
    z-index: 5;
  }

  .radar-blip {
    position: absolute;
    top: 35%;
    left: 60%;
    width: 5px;
    height: 5px;
    background-color: var(--neon-rose);
    border-radius: 50%;
    display: none;
    z-index: 4;
  }

  @keyframes sweep {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes blipPulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 39, 67, 0.8); }
    70% { transform: scale(1.5); box-shadow: 0 0 0 8px rgba(220, 39, 67, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 39, 67, 0); }
  }

  /*  LASER DE ESCANEO DE CARD */
  .scanning-bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(0, 240, 255, 0) 0%, rgba(0, 240, 255, 0.8) 50%, rgba(0, 240, 255, 0) 100%);
    box-shadow: 0 0 10px rgba(0, 240, 255, 0.6);
    z-index: 10;
    animation: scan 2s linear infinite;
    display: none;
  }

  @keyframes scan {
    0% { top: 0%; }
    50% { top: 100%; }
    100% { top: 0%; }
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(0, 240, 255, 0.4);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(0, 240, 255, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(0, 240, 255, 0);
    }
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background-color: var(--neon-blue);
    border-radius: 50%;
    display: inline-block;
    animation: pulse 1.5s infinite;
  }
</style>
